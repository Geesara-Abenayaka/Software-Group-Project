# Database
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/your_database
PORT=5000

# SendGrid (required for real email delivery)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=admissions@uom.lk
SENDGRID_FROM_NAME=University of Moratuwa PG Admissions
SENDGRID_REPLY_TO=admissions@uom.lk

# Optional: Gemini Vision OCR for image extraction (recommended)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_VISION_MODEL=gemini-1.5-flash

# Optional for local testing without delivering real emails.
# Set to true only if you intentionally want simulation mode.
EMAIL_SIMULATION=false
